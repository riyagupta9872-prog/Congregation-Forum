rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // HELPERS
    // =========================================================================

    function isAuthed() {
      return request.auth != null;
    }

    // Returns the caller's Firestore profile doc.
    // Returns {} if the doc doesn't exist yet (new signup, awaiting approval).
    function me() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : {};
    }

    function myRole() { return me().get('role', ''); }
    function myTeam() { return me().get('team', ''); }

    // Role checks
    function isSuperAdmin()     { return isAuthed() && myRole() == 'superAdmin'; }
    function isTeamAdmin()      { return isAuthed() && myRole() == 'teamAdmin'; }
    function isServiceDevotee() { return isAuthed() && myRole() == 'serviceDevotee'; }
    function isCoordinator()    { return isTeamAdmin() || isServiceDevotee(); }

    // Delegation flags (superAdmin always passes; flags are additive)
    function canManageAll()        { return isSuperAdmin() || me().get('canManageAllTeams', false) == true; }
    function canCrossTeamCalling() { return canManageAll() || me().get('canAllTeamCalling',  false) == true; }
    function canCrossTeamReports() { return canManageAll() || me().get('canAllTeamReports',  false) == true; }


    // =========================================================================
    // users/{userId}
    // =========================================================================
    match /users/{userId} {
      // Own profile always readable; admins can read all (user management panel)
      allow read: if isAuthed() && (request.auth.uid == userId || canManageAll());

      // Create:
      //   • Admins create docs via approveSignupRequest()
      //   • Any authed user may create their OWN doc (first-user bootstrap — in
      //     the normal flow a superAdmin approval creates this doc instead)
      allow create: if isAuthed() && (
        canManageAll() || request.auth.uid == userId
      );

      // Only admins can change roles, teams, or delegation flags
      allow update: if isAuthed() && canManageAll();

      // Users are never hard-deleted
      allow delete: if false;
    }


    // =========================================================================
    // signupRequests/{reqId}
    // =========================================================================
    match /signupRequests/{reqId} {
      // Any authed user can submit a request (they have a Firebase Auth account
      // but no users/{uid} doc yet — me() returns {} which is safe here)
      allow create: if isAuthed();

      // Users can read their own pending request ("awaiting approval" message)
      allow read: if isAuthed() && (
        resource.data.get('uid', '') == request.auth.uid || canManageAll()
      );

      // Only admins can approve (update) or dismiss (delete)
      allow update, delete: if isAuthed() && canManageAll();
    }


    // =========================================================================
    // devotees/{devoteeId}
    // =========================================================================
    match /devotees/{devoteeId} {
      allow read: if isAuthed();

      // Admins can create any devotee; teamAdmins create within their team
      allow create: if isAuthed() && (canManageAll() || isTeamAdmin());

      // Soft-delete (isActive: false) and profile edits
      // Admins: any devotee. TeamAdmin: only their own team's devotees.
      allow update: if isAuthed() && (
        canManageAll() ||
        (isTeamAdmin() && resource.data.get('teamName', '') == myTeam())
      );

      // Hard deletes are forbidden — soft-delete via isActive: false
      allow delete: if false;
    }

    // Audit subcollections under devotees (editHistory, auditLog, etc.)
    match /devotees/{devoteeId}/{auditColl}/{auditDocId} {
      allow read:          if isAuthed() && (canManageAll() || isTeamAdmin());
      allow create:        if isAuthed() && (canManageAll() || isTeamAdmin());
      allow update, delete: if false; // Immutable audit trail
    }


    // =========================================================================
    // profileChanges/{docId}   — top-level audit trail for devotee profile edits
    // =========================================================================
    match /profileChanges/{docId} {
      allow read:          if isAuthed() && (canManageAll() || isTeamAdmin());
      allow create:        if isAuthed() && (canManageAll() || isTeamAdmin());
      allow update, delete: if false; // Immutable
    }


    // =========================================================================
    // sessions/{sessionId}
    // =========================================================================
    match /sessions/{sessionId} {
      allow read: if isAuthed();

      // Sessions created lazily via getOrCreateSession() — any coordinator triggers this
      allow create: if isAuthed() && (canManageAll() || isCoordinator());

      // Only admins cancel sessions or edit metadata (topic, isCancelled)
      allow update: if isAuthed() && canManageAll();
      allow delete: if false;
    }


    // =========================================================================
    // attendanceRecords/{recordId}
    // =========================================================================
    match /attendanceRecords/{recordId} {
      allow read: if isAuthed();

      // Any coordinator can mark / unmark attendance.
      // canBackDateAttendance flag is enforced in app logic — checking it here
      // would require a session join read, which is impractical in rules.
      allow create, update: if isAuthed() && (canManageAll() || isCoordinator());

      // clearDataForDate / clearAllData are superAdmin-only
      allow delete: if isAuthed() && canManageAll();
    }


    // =========================================================================
    // callingStatus/{docId}
    // =========================================================================
    match /callingStatus/{docId} {
      allow read: if isAuthed();

      // TeamAdmin submits for their own team.
      // canCrossTeamCalling (or canManageAll) lifts the team restriction.
      allow write: if isAuthed() && (canCrossTeamCalling() || isTeamAdmin());
    }


    // =========================================================================
    // callingSubmissions/{docId}   — submission timestamps per coordinator/week
    // =========================================================================
    match /callingSubmissions/{docId} {
      allow read: if isAuthed();
      allow write: if isAuthed() && (canCrossTeamCalling() || isTeamAdmin());
    }


    // =========================================================================
    // callingStatusChanges/{docId}   — immutable audit trail for calling edits
    // =========================================================================
    match /callingStatusChanges/{docId} {
      allow read: if isAuthed() && (
        canManageAll() || isTeamAdmin() || canCrossTeamReports()
      );
      allow create: if isAuthed() && (canCrossTeamCalling() || isTeamAdmin());
      allow update, delete: if false; // Immutable
    }


    // =========================================================================
    // personalMeetings/{meetingId}   — Connecting tab / PTM logs
    // =========================================================================
    match /personalMeetings/{meetingId} {
      allow read: if isAuthed();

      allow create: if isAuthed() && (canManageAll() || isCoordinator());

      // Creator or any teamAdmin/admin can update (edit outcome, date, notes)
      allow update: if isAuthed() && (
        canManageAll() ||
        resource.data.get('createdBy', '') == request.auth.uid ||
        isTeamAdmin()
      );

      // Only the creator or an admin can delete a meeting record
      allow delete: if isAuthed() && (
        canManageAll() ||
        resource.data.get('createdBy', '') == request.auth.uid
      );
    }


    // =========================================================================
    // interactions/{docId}   — calling interaction log entries
    // =========================================================================
    match /interactions/{docId} {
      allow read: if isAuthed();
      allow create: if isAuthed() && (canManageAll() || isCoordinator());
      allow update: if isAuthed() && (
        canManageAll() ||
        resource.data.get('createdBy', '') == request.auth.uid ||
        isTeamAdmin()
      );
      // Bulk deletes (clearAllData) are superAdmin-only
      allow delete: if isAuthed() && canManageAll();
    }


    // =========================================================================
    // events/{eventId}
    // =========================================================================
    match /events/{eventId} {
      allow read:  if isAuthed();
      allow write: if isAuthed() && (canManageAll() || isTeamAdmin());
    }


    // =========================================================================
    // eventDevotees/{docId}
    // =========================================================================
    match /eventDevotees/{docId} {
      allow read:  if isAuthed();
      allow write: if isAuthed() && (canManageAll() || isTeamAdmin());
    }


    // =========================================================================
    // settings/{settingId}   — callingWeek · attendanceTargets · migrations
    // =========================================================================
    match /settings/{settingId} {
      // All authenticated users need to read settings (callingWeek drives the
      // calling UI; attendanceTargets drives the attendance progress bar)
      allow read: if isAuthed();

      // Only superAdmin configures global settings or triggers migrations
      allow write: if isAuthed() && isSuperAdmin();
    }


    // =========================================================================
    // Catch-all — deny everything not explicitly matched above
    // =========================================================================
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
